<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:grafico="using:CalculadoraGrafica.Interface.Grafico"
        xmlns:listafuncoes="using:ListaFuncoes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CalculadoraGrafica.Interface.MainWindow"
        Title="CalculadoraGrafica.Interface">
    <Grid ColumnDefinitions="Auto, *">
        <listafuncoes:ListaFuncoesView Grid.Column="0"/>
        <grafico:GraficoControl Grid.Column="1"/>
    </Grid>
</Window>
